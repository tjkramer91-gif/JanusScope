{
  "name": "subscope-risk-review",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run check-sensitive-content && npm run check-runtime-sensitive-data",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --pool=forks --maxWorkers=1",
    "test:watch": "vitest --pool=forks --maxWorkers=1",
    "check-sensitive-content": "node scripts/check-sensitive-content.mjs",
    "check-runtime-sensitive-data": "node scripts/check-runtime-sensitive-data.mjs",
    "privacy:audit": "npm run check-sensitive-content && npm run check-runtime-sensitive-data"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "@vercel/functions": "^3.7.1",
    "next": "^15.5.7",
    "playwright": "^1.61.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "^22.18.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.35.0",
    "eslint-config-next": "^15.5.7",
    "postcss": "8.5.10",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
