NEXT_PUBLIC_APP_URL=http://localhost:3000

# Used to sign the SubScope email/password session cookie.
# In production, set this to a long random string.
SESSION_SECRET=replace-with-a-long-random-secret

# Supabase persistence. Required for durable production project and document records.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Private bucket for uploaded binaries. Required in production when Supabase persistence is enabled.
SUPABASE_UPLOAD_BUCKET=subscope-documents

# Optional local development override. Defaults to .data locally.
SUBSCOPE_DATA_DIR=

# Temporary QA switches. Leave unset in production unless explicitly needed.
ENABLE_DEMO_ACCESS=
ALLOW_RUNTIME_CACHE_STORE_FALLBACK=

# Legacy Auth0 variables are still accepted for older callback routes, but email/password auth uses SESSION_SECRET.
AUTH0_SECRET=
AUTH0_BASE_URL=
AUTH0_ISSUER_BASE_URL=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
